@model ProductDetailsVM

@{
    ViewData["Title"] = "Admin – Product Details";
}

<h2 class="mb-4">
    <i class="fa-solid fa-circle-info me-2 text-info"></i>Product Details
</h2>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Id</dt>
            <dd class="col-sm-9">@Model.Id</dd>

            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9 fw-semibold">@Model.Name</dd>

            <dt class="col-sm-3">SKU</dt>
            <dd class="col-sm-9">
                <span class="badge bg-light text-dark border">@Model.SKU</span>
            </dd>

            <dt class="col-sm-3">Price</dt>
            <dd class="col-sm-9 text-success fw-bold fs-5">@Model.Price.ToString("C")</dd>

            <dt class="col-sm-3">Stock</dt>
            <dd class="col-sm-9">
                @if (Model.StockQuantity > 0)
                {
                    <span class="text-success">
                        <i class="fa-solid fa-circle-check me-1"></i>@Model.StockQuantity in stock
                    </span>
                }
                else
                {
                    <span class="text-danger">
                        <i class="fa-solid fa-circle-xmark me-1"></i>Out of stock
                    </span>
                }
            </dd>

            <dt class="col-sm-3">Category</dt>
            <dd class="col-sm-9">@Model.CategoryName</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                <span class="badge @(Model.IsActive ? "bg-success" : "bg-secondary")">
                    @(Model.IsActive ? "Active" : "Inactive")
                </span>
            </dd>
        </dl>
    </div>
</div>

<div class="d-flex gap-2">
    <a asp-area="Admin" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
        <i class="fa-solid fa-pen-to-square me-1"></i>Edit
    </a>
    <a asp-area="Admin" asp-action="Index" class="btn btn-outline-secondary">
        <i class="fa-solid fa-arrow-left me-1"></i>Back to List
    </a>
</div>