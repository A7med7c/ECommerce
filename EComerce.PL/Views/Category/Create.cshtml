@model AddCategoryVM

<div class="row justify-content-center align-content-center mt-3">
    <h1 class="col-8 my-4">Create Category</h1>

    <form class="col-8" method="post" asp-action="Create">
        <div class="form-group mb-3">
            <label class="form-label" asp-for="Name"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label class="form-label">Parent Category</label>

            <select asp-for="ParentCategoryId" class="form-select">
                <option value="">-- Main Category --</option>

                @foreach (var category in ViewBag.Categories)
                {
                    <option value="@category.CategoryId">
                        @category.Name
                    </option>
                }
            </select>
        </div>

        <div class="mt-4">
            <input class="btn btn-primary" type="submit" value="Create" />
            <a class="btn btn-outline-dark" asp-action="Index">
                Back to list
            </a>
        </div>

    </form>
</div>