@model CategoryDetailsVM

@{
    ViewData["Title"] = "Admin – Delete Category";
}

<div class="row justify-content-center mt-4">
    <div class="col-6">
        <div class="card shadow border-0">
            <div class="card-body text-center">

                <h3 class="text-danger mb-4">
                    <i class="fa-solid fa-triangle-exclamation me-2"></i>Confirm Delete
                </h3>

                <p class="fs-5">Are you sure you want to delete this category?</p>

                <h4 class="text-primary fw-bold">@Model.Name</h4>
                <p class="text-muted">
                    @(Model.ParentCategoryId == null ? "Main Category" : "Sub Category")
                </p>

                <hr />

                <form asp-area="Admin" asp-controller="Category" asp-action="Delete" asp-route-id="@Model.Id"
                      method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger me-2">
                        <i class="fa-solid fa-trash me-1"></i>Delete
                    </button>
                    <a asp-area="Admin" asp-action="Index" class="btn btn-outline-secondary">
                        <i class="fa-solid fa-xmark me-1"></i>Cancel
                    </a>
                </form>

            </div>
        </div>
    </div>
</div>