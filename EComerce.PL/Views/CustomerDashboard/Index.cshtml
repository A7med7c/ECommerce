@using ECommerce.BLL.ViewModels.Order
@model IEnumerable<OrdersVM>

@{
    ViewData["Title"] = "My Orders";
}

<h2 class="mb-4">My Orders</h2>
<p class="text-muted">Track and manage your orders.</p>

@if (!Model.Any())
{
    <div class="alert alert-info">
        You haven't placed any orders yet.
        <a asp-controller="Catalog" asp-action="Index" class="alert-link">Start shopping</a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Order #</th>
                    <th>Date</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th class="text-end">Details</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td>#@order.Id</td>
                        <td>@order.OrderDate.ToString("MMM d, yyyy")</td>
                        <td>@order.TotalAmount.ToString("C")</td>
                        <td><span class="badge bg-secondary">@order.Status</span></td>
                        <td class="text-end">
                            <a asp-controller="Order" asp-action="Details" asp-route-id="@order.Id"
                               class="btn btn-sm btn-outline-primary">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}