@model ProductCreateUpdateVM

@{
    ViewData["Title"] = "Edit Product";
}

<h2>Edit Product</h2>

<form asp-action="Edit" method="post">

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <input type="hidden" asp-for="Id" />

    <partial name="_ProductForm" model="Model" />

    <button type="submit" class="btn btn-warning"><i class="fa-solid fa-pen-to-square me-1"></i>Update</button>
    <a asp-action="Index" class="btn btn-secondary"><i class="fa-solid fa-xmark me-1"></i>Cancel</a>

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}