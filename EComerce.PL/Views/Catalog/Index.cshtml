@model ProductListVM

@{
    ViewData["Title"] = "Shop";
}

<div class="row g-4">

    <!-- LEFT SIDEBAR FILTERS -->
    <div class="col-lg-3 col-xl-2">
        <div class="filter-sidebar sticky-top" style="top:5rem">
            <div class="filter-header">
                <i class="fa-solid fa-sliders me-2"></i>Filter Products
            </div>
            <div class="filter-body">
                <form asp-action="Index" method="get" id="filterForm">

                    <div class="mb-3">
                        <label class="form-label">Search</label>
                        <div class="input-group">
                            <input type="text" name="q" value="@Model.Q" class="form-control"
                                   placeholder="Name or SKU..." />
                            <button class="btn btn-outline-secondary" type="submit">
                                <i class="fa-solid fa-magnifying-glass"></i>
                            </button>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Category</label>
                        <select name="categoryId" class="form-select" onchange="this.form.submit()"
                                asp-items="@(new SelectList(Model.Categories, nameof(CategoryFilterVM.Id), nameof(CategoryFilterVM.Name), Model.CategoryId))">
                            <option value="">All Categories</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Sort By</label>
                        <select name="sort" class="form-select" onchange="this.form.submit()"
                                asp-items="@(new SelectList(new[]
                                {
                                    new { Value = "newest",     Text = "Newest First" },
                                    new { Value = "price_asc",  Text = "Price: Low - High" },
                                    new { Value = "price_desc", Text = "Price: High - Low" }
                                }, "Value", "Text", Model.Sort))">
                        </select>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Q) || Model.CategoryId.HasValue)
                    {
                        <a asp-action="Index" class="btn btn-sm btn-outline-danger w-100">
                            <i class="fa-solid fa-xmark me-1"></i>Clear Filters
                        </a>
                    }

                </form>
            </div>
        </div>
    </div>

    <!-- RIGHT SIDE - PRODUCTS GRID -->
    <div class="col-lg-9 col-xl-10">

        <!-- Top bar with sort info -->
        <div class="d-flex align-items-center justify-content-between mb-3">
            <p class="text-muted small mb-0">
                Showing <strong>@Model.Products.Count</strong> of
                <strong>@Model.TotalCount</strong> products
                @if (!string.IsNullOrEmpty(Model.Q))
                {
                    <span>for &ldquo;<em>@Model.Q</em>&rdquo;</span>
                }
            </p>
            <!-- Sort pills for desktop -->
            <div class="d-none d-md-flex gap-1">
                <a asp-action="Index" asp-route-categoryId="@Model.CategoryId" asp-route-q="@Model.Q" asp-route-sort="newest"
                   class="btn btn-sm @(Model.Sort == "newest" ? "btn-primary" : "btn-outline-secondary")">Newest</a>
                <a asp-action="Index" asp-route-categoryId="@Model.CategoryId" asp-route-q="@Model.Q" asp-route-sort="price_asc"
                   class="btn btn-sm @(Model.Sort == "price_asc" ? "btn-primary" : "btn-outline-secondary")">Price Low</a>
                <a asp-action="Index" asp-route-categoryId="@Model.CategoryId" asp-route-q="@Model.Q" asp-route-sort="price_desc"
                   class="btn btn-sm @(Model.Sort == "price_desc" ? "btn-primary" : "btn-outline-secondary")">Price High</a>
            </div>
        </div>

        @if (Model.Products.Any())
        {
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
                @foreach (var product in Model.Products)
                {
                    <div class="col">
                        <div class="product-card h-100 d-flex flex-column">
                            <div class="img-wrapper">
                                <a asp-action="Details" asp-route-id="@product.Id">
                                    @if (!string.IsNullOrEmpty(product.ImageUrl))
                                    {
                                        <img src="@product.ImageUrl" alt="@product.Name" class="card-img-top" />
                                    }
                                    else
                                    {
                                        <div class="bg-light d-flex align-items-center justify-content-center" style="height:220px">
                                            <i class="fa-solid fa-image fa-3x text-muted"></i>
                                        </div>
                                    }
                                </a>
                            </div>
                            <div class="card-body d-flex flex-column px-3 pt-3 pb-2">
                                <span class="cat-badge mb-2">@product.CategoryName</span>
                                <h6 class="card-title fw-semibold mb-1" style="font-size:.875rem;line-height:1.4">@product.Name</h6>
                                <div class="product-rating mb-2">
                                    <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star-half-stroke"></i>
                                    <span class="rating-count">(4.5)</span>
                                </div>
                                <p class="product-price mt-auto mb-1">@product.Price.ToString("C")</p>
                                @if (product.StockQuantity > 0)
                                {
                                    <p class="stock-ok mb-0"><i class="fa-solid fa-circle-check me-1"></i>In stock</p>
                                }
                                else
                                {
                                    <p class="stock-out mb-0"><i class="fa-solid fa-circle-xmark me-1"></i>Out of stock</p>
                                }
                            </div>
                            <div class="card-footer d-flex gap-2">
                                <a asp-action="Details" asp-route-id="@product.Id"
                                   class="btn btn-sm btn-outline-primary flex-grow-1">
                                    <i class="fa-solid fa-circle-info me-1"></i>Details
                                </a>
                                @if (product.IsActive && product.StockQuantity > 0)
                                {
                                    <form asp-controller="Cart" asp-action="Add" method="post" class="d-inline" data-async="cart">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="productId" value="@product.Id" />
                                        <input type="hidden" name="quantity" value="1" />
                                        <button type="submit" class="btn btn-sm btn-primary" title="Add to Cart">
                                            <i class="fa-solid fa-cart-plus"></i>
                                        </button>
                                    </form>
                                }
                                @if (User.Identity != null && User.Identity.IsAuthenticated)
                                {
                                    <form asp-controller="Favorite" asp-action="Add" method="post" data-async="favorite">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="productId" value="@product.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Add to Favourites">
                                            <i class="fa-solid fa-heart"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <nav class="mt-4" aria-label="Page navigation">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                            <a class="page-link" asp-action="Index"
                               asp-route-categoryId="@Model.CategoryId" asp-route-q="@Model.Q"
                               asp-route-sort="@Model.Sort" asp-route-page="@(Model.CurrentPage - 1)">
                                <i class="fa-solid fa-chevron-left"></i>
                            </a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" asp-action="Index"
                                   asp-route-categoryId="@Model.CategoryId" asp-route-q="@Model.Q"
                                   asp-route-sort="@Model.Sort" asp-route-page="@i">@i</a>
                            </li>
                        }
                        <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                            <a class="page-link" asp-action="Index"
                               asp-route-categoryId="@Model.CategoryId" asp-route-q="@Model.Q"
                               asp-route-sort="@Model.Sort" asp-route-page="@(Model.CurrentPage + 1)">
                                <i class="fa-solid fa-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            }
        }
        else
        {
            <div class="empty-state">
                <div class="empty-icon"><i class="fa-solid fa-box-open"></i></div>
                <h4>No products found</h4>
                <p>Try adjusting your search or filter criteria.</p>
                @if (!string.IsNullOrEmpty(Model.Q) || Model.CategoryId.HasValue)
                {
                    <a asp-action="Index" class="btn btn-primary">
                        <i class="fa-solid fa-xmark me-1"></i>Clear Filters
                    </a>
                }
            </div>
        }
    </div>
</div>
