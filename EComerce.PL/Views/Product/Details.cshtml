@model ProductDetailsVM

@{
    ViewData["Title"] = "Product Details";
}

<h2>Product Details</h2>

<div class="card">
    <div class="card-body">
        <h4>@Model.Name</h4>
        <p><strong>SKU:</strong> @Model.SKU</p>
        <p><strong>Price:</strong> @Model.Price.ToString("C")</p>
        <p><strong>Stock:</strong> @Model.StockQuantity</p>
        <p><strong>Category:</strong> @Model.CategoryName</p>
        <p><strong>Status:</strong> @(Model.IsActive ? "Active" : "Inactive")</p>
    </div>
</div>

<a asp-action="Index" class="btn btn-secondary mt-3"><i class="fa-solid fa-arrow-left me-1"></i>Back To List</a>