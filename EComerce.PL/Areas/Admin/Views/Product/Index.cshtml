@model ProductListVM

@{
    ViewData["Title"] = "Admin - Products";
}

<div class="row g-4">

    <div class="col-lg-10">

        
        <div class="row g-3 mb-4">
            <div class="col-sm-4">
                <div class="admin-stat-card">
                    <div class="stat-icon" style="background:var(--shop-primary-light);color:var(--shop-primary)">
                        <i class="fa-solid fa-boxes-stacked"></i>
                    </div>
                    <div class="stat-info">
                        <div class="stat-value">@Model.TotalCount</div>
                        <div class="stat-label">Total Products</div>
                    </div>
                </div>
            </div>
            <div class="col-sm-4">
                <div class="admin-stat-card">
                    <div class="stat-icon" style="background:#f0fdf4;color:#059669">
                        <i class="fa-solid fa-tags"></i>
                    </div>
                    <div class="stat-info">
                        <div class="stat-value">@Model.Categories.Count</div>
                        <div class="stat-label">Categories</div>
                    </div>
                </div>
            </div>
            <div class="col-sm-4">
                <div class="admin-stat-card">
                    <div class="stat-icon" style="background:#fffbeb;color:#f59e0b">
                        <i class="fa-solid fa-clipboard-list"></i>
                    </div>
                    <div class="stat-info">
                        <div class="stat-value">@Model.Products.Count(p => p.StockQuantity == 0)</div>
                        <div class="stat-label">Out of Stock</div>
                    </div>
                </div>
            </div>
        </div>

        
        <div class="d-flex align-items-center justify-content-between mb-4">
            <div>
                <h2 class="section-title mb-1">
                    <i class="fa-solid fa-boxes-stacked me-2" style="color:var(--shop-primary)"></i>Products
                </h2>
                <p class="section-subtitle mb-0">Manage your product catalog</p>
            </div>
            <a asp-area="Admin" asp-action="Create" class="btn btn-primary">
                <i class="fa-solid fa-plus me-1"></i>Add Product
            </a>
        </div>

        
        <div class="card mb-4">
            <div class="card-body py-3">
                <form asp-area="Admin" asp-action="Index" method="get" class="row g-2 align-items-end">
                    <div class="col-sm-5">
                        <label class="form-label text-muted small mb-1">Search</label>
                        <div class="input-group">
                            <input type="text" name="q" value="@Model.Q" class="form-control"
                                   placeholder="Search by name or SKU..." />
                            <button class="btn btn-primary" type="submit">
                                <i class="fa-solid fa-magnifying-glass"></i>
                            </button>
                        </div>
                    </div>
                    <div class="col-sm-3">
                        <label class="form-label text-muted small mb-1">Category</label>
                        <select name="categoryId" class="form-select" onchange="this.form.submit()"
                                asp-items="@(new SelectList(Model.Categories, nameof(CategoryFilterVM.Id), nameof(CategoryFilterVM.Name), Model.CategoryId))">
                            <option value="">All Categories</option>
                        </select>
                    </div>
                    <div class="col-sm-2">
                        <label class="form-label text-muted small mb-1">Sort</label>
                        <select name="sort" class="form-select" onchange="this.form.submit()"
                                asp-items="@(new SelectList(new[]
                                {
                                    new { Value = "newest",     Text = "Newest" },
                                    new { Value = "price_asc",  Text = "Price Asc" },
                                    new { Value = "price_desc", Text = "Price Desc" }
                                }, "Value", "Text", Model.Sort))">
                        </select>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Q) || Model.CategoryId.HasValue)
                    {
                        <div class="col-sm-2">
                            <label class="form-label text-muted small mb-1">&nbsp;</label>
                            <a asp-area="Admin" asp-action="Index" class="btn btn-outline-danger w-100 d-block">
                                <i class="fa-solid fa-xmark me-1"></i>Clear
                            </a>
                        </div>
                    }
                </form>
            </div>
        </div>

        <p class="text-muted small mb-3">
            Showing <strong>@Model.Products.Count</strong> of <strong>@Model.TotalCount</strong> products
        </p>

        @if (Model.Products.Any())
        {
            <div class="card">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th class="ps-4" style="width:60px">Image</th>
                                <th>Name</th>
                                <th>Category</th>
                                <th>Price</th>
                                <th class="text-center">Stock</th>
                                <th class="text-center">Status</th>
                                <th class="text-center pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Products)
                            {
                                <tr>
                                    <td class="ps-4">
                                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                                        {
                                            <img src="@item.ImageUrl" alt="@item.Name" class="admin-img" />
                                        }
                                        else
                                        {
                                            <div class="admin-img-placeholder">
                                                <i class="fa-solid fa-image"></i>
                                            </div>
                                        }
                                    </td>
                                    <td>
                                        <p class="fw-semibold mb-0" style="font-size:.875rem">@item.Name</p>
                                        <span class="text-muted" style="font-size:.75rem">@item.SKU</span>
                                    </td>
                                    <td><span class="cat-badge">@item.CategoryName</span></td>
                                    <td class="fw-bold" style="color:var(--shop-primary)">@item.Price.ToString("C")</td>
                                    <td class="text-center">
                                        @if (item.StockQuantity > 0)
                                        {
                                            <span class="status-badge status-active">@item.StockQuantity</span>
                                        }
                                        else
                                        {
                                            <span class="status-badge status-warning">0</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (item.IsActive)
                                        {
                                            <span class="status-badge status-active">
                                                <i class="fa-solid fa-check"></i>Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="status-badge status-inactive">
                                                <i class="fa-solid fa-xmark"></i>Inactive
                                            </span>
                                        }
                                    </td>
                                    <td class="text-center pe-4 text-nowrap">
                                        <a asp-area="Admin" asp-action="Details" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-secondary me-1" title="Details">
                                            <i class="fa-solid fa-circle-info"></i>
                                        </a>
                                        <a asp-area="Admin" asp-action="Edit" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-primary me-1" title="Edit">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </a>
                                        <button type="button" class="btn btn-sm btn-outline-danger delete-btn"
                                                data-id="@item.Id"
                                                data-message="Product &lsquo;@item.Name&rsquo; will be permanently deleted!"
                                                title="Delete">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            
            @if (Model.TotalPages > 1)
            {
                <nav class="mt-4" aria-label="Page navigation">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                            <a class="page-link" asp-area="Admin" asp-action="Index"
                               asp-route-q="@Model.Q" asp-route-sort="@Model.Sort"
                               asp-route-categoryId="@Model.CategoryId"
                               asp-route-page="@(Model.CurrentPage - 1)">
                                <i class="fa-solid fa-chevron-left"></i>
                            </a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" asp-area="Admin" asp-action="Index"
                                   asp-route-q="@Model.Q" asp-route-sort="@Model.Sort"
                                   asp-route-categoryId="@Model.CategoryId"
                                   asp-route-page="@i">@i</a>
                            </li>
                        }
                        <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                            <a class="page-link" asp-area="Admin" asp-action="Index"
                               asp-route-q="@Model.Q" asp-route-sort="@Model.Sort"
                               asp-route-categoryId="@Model.CategoryId"
                               asp-route-page="@(Model.CurrentPage + 1)">
                                <i class="fa-solid fa-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            }
        }
        else
        {
            <div class="empty-state">
                <div class="empty-icon"><i class="fa-solid fa-boxes-stacked"></i></div>
                <h4>No products found</h4>
                <p>Try adjusting your search criteria or add a new product.</p>
            </div>
        }

    </div>
</div>

<form id="deleteForm" asp-area="Admin" asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="deleteId" />
</form>
