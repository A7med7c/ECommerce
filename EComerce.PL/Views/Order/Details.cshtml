@model OrderDetailsVM

@{
    ViewData["Title"] = $"Order {Model.OrderNumber}";

    var badgeClass = Model.Status switch
    {
        "Pending" => "bg-warning text-dark",
        "Processing" => "bg-info text-dark",
        "Shipped" => "bg-primary",
        "Delivered" => "bg-success",
        "Cancelled" => "bg-secondary",
        _ => "bg-light text-dark"
    };
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h2 class="mb-0">
        <i class="fa-solid fa-receipt me-2 text-primary"></i>
        Order <span class="text-primary">@Model.OrderNumber</span>
    </h2>
    <span class="badge fs-6 @badgeClass">@Model.Status</span>
</div>

<div class="row g-4 mb-4">

    <!-- Order Info -->
    <div class="col-md-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-light fw-semibold">
                <i class="fa-solid fa-circle-info me-2"></i>Order Information
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Order Number</dt>
                    <dd class="col-sm-7">@Model.OrderNumber</dd>

                    <dt class="col-sm-5">Status</dt>
                    <dd class="col-sm-7"><span class="badge @badgeClass">@Model.Status</span></dd>

                    <dt class="col-sm-5">Date</dt>
                    <dd class="col-sm-7">@Model.OrderDate.ToString("dd MMM yyyy HH:mm")</dd>

                    <dt class="col-sm-5">Total</dt>
                    <dd class="col-sm-7 fw-bold text-success fs-5">@Model.TotalAmount.ToString("C")</dd>
                </dl>
            </div>
        </div>
    </div>

    <!-- Shipping Address -->
    <div class="col-md-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-light fw-semibold">
                <i class="fa-solid fa-location-dot me-2"></i>Shipping Address
            </div>
            <div class="card-body">
                <address class="mb-0">
                    <strong>@Model.ShippingStreet</strong><br />
                    @Model.ShippingCity, @Model.ShippingZip<br />
                    @Model.ShippingCountry
                </address>
            </div>
        </div>
    </div>

</div>

<!-- Line Items -->
<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-light fw-semibold">
        <i class="fa-solid fa-list me-2"></i>Order Items
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Product</th>
                        <th>SKU</th>
                        <th class="text-center">Qty</th>
                        <th class="text-end">Unit Price</th>
                        <th class="text-end pe-4">Line Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="ps-4 fw-semibold">@item.ProductName</td>
                            <td><span class="badge bg-light text-dark border">@item.SKU</span></td>
                            <td class="text-center">@item.Quantity</td>
                            <td class="text-end text-muted">@item.UnitPrice.ToString("C")</td>
                            <td class="text-end fw-semibold text-success pe-4">@item.LineTotal.ToString("C")</td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-light">
                    <tr>
                        <td colspan="4" class="text-end fw-bold ps-4">Order Total</td>
                        <td class="text-end fw-bold text-success fs-5 pe-4">@Model.TotalAmount.ToString("C")</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

<div class="d-flex gap-2">
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="fa-solid fa-arrow-left me-1"></i>Back to Orders
    </a>

    @if (Model.Status != "Cancelled" && Model.Status != "Delivered")
    {
        <form asp-action="Cancel" method="post" class="d-inline"
              onsubmit="return confirm('Cancel order @Model.OrderNumber?')">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn btn-danger">
                <i class="fa-solid fa-ban me-1"></i>Cancel Order
            </button>
        </form>
    }
</div>