@model CategoryDetailsVM

@{
    ViewData["Title"] = "Admin – Category Details";
}

<div class="row justify-content-center mt-4">
    <div class="col-8">

        <h2 class="mb-4">
            <i class="fa-solid fa-circle-info me-2 text-info"></i>Category Details
        </h2>

        <div class="card shadow-sm">
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Id</dt>
                    <dd class="col-sm-8">@Model.Id</dd>

                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@Model.Name</dd>

                    <dt class="col-sm-4">Parent Category</dt>
                    <dd class="col-sm-8">@(Model.ParentCategoryName ?? "Main Category")</dd>

                    <dt class="col-sm-4">Created By</dt>
                    <dd class="col-sm-8">@Model.CreatedBy</dd>

                    <dt class="col-sm-4">Created On</dt>
                    <dd class="col-sm-8">@Model.CreatedOn.ToString("dd MMM yyyy")</dd>

                    <dt class="col-sm-4">Modified By</dt>
                    <dd class="col-sm-8">@Model.ModifiedBy</dd>

                    <dt class="col-sm-4">Modified On</dt>
                    <dd class="col-sm-8">@Model.ModifiedOn.ToString("dd MMM yyyy")</dd>

                    <dt class="col-sm-4">Is Deleted</dt>
                    <dd class="col-sm-8">
                        <span class="badge @(Model.IsDeleted ? "bg-danger" : "bg-success")">
                            @(Model.IsDeleted ? "Deleted" : "Active")
                        </span>
                    </dd>
                </dl>
            </div>
        </div>

        <div class="mt-3">
            <a asp-area="Admin" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                <i class="fa-solid fa-pen-to-square me-1"></i>Edit
            </a>
            <a asp-area="Admin" asp-action="Index" class="btn btn-outline-secondary">
                <i class="fa-solid fa-arrow-left me-1"></i>Back to List
            </a>
        </div>

    </div>
</div>