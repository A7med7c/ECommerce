@model UpdateCategoryVM

<div class="row justify-content-center align-content-center mt-3">

    <h1 class="col-8 my-4">Edit Category</h1>

    <form class="col-8" method="post" asp-action="Edit">

        <!-- Hidden Id -->
        <input type="hidden" asp-for="CategoryId" />

        <!-- Name -->
        <div class="form-group mb-3">
            <label class="form-label" asp-for="Name"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <!-- Parent Category -->
        <div class="form-group mb-3">
            <label class="form-label">Parent Category</label>

            <select asp-for="ParentCategoryId" class="form-select">

                <option value="">-- Main Category --</option>

                @foreach (var category in ViewBag.ParentCategories)
                {
                    <option value="@category.CategoryId">
                        @category.Name
                    </option>
                }

            </select>

            <span asp-validation-for="ParentCategoryId"
                  class="text-danger"></span>
        </div>

        <!-- Buttons -->
        <div class="mt-4">
            <input class="btn btn-success" type="submit" value="Update" />
            <a class="btn btn-outline-dark" asp-action="Index">
                Cancel
            </a>
        </div>

    </form>

</div>