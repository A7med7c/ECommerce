@model IEnumerable<FavoriteVM>

@{
    ViewData["Title"] = "My Favourites";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h2 class="mb-0">
        <i class="fa-solid fa-heart text-danger me-2"></i>My Favourites
    </h2>
    <a asp-controller="Catalog" asp-action="Index" class="btn btn-outline-primary">
        <i class="fa-solid fa-shop me-1"></i>Browse Shop
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fa-solid fa-circle-xmark me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (Model.Any())
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0">

                    <!-- Image -->
                    <a asp-controller="Catalog" asp-action="Details" asp-route-id="@item.ProductId">
                        @if (!string.IsNullOrEmpty(item.ProductImageUrl))
                        {
                            <img src="@item.ProductImageUrl" alt="@item.ProductName"  class="card-img-top object-fit-cover"
                                 style="height:180px" />
                        }
                        else
                        {
                            <div class="bg-light d-flex align-items-center justify-content-center"                      style="height:180px">
                                <i class="fa-solid fa-image fa-3x text-muted"></i>
                            </div>
                        }
                    </a>

                    <div class="card-body d-flex flex-column">
                        <span class="badge bg-light text-dark border mb-2 align-self-start small">
                            @item.CategoryName
                        </span>
                        <h6 class="card-title fw-semibold">@item.ProductName</h6>
                        <p class="text-success fw-bold fs-5 mt-auto mb-1">
                            @item.ProductPrice.ToString("C")
                        </p>
                        @if (item.StockQuantity > 0)
                        {
                            <p class="text-muted small mb-0">
                                <i class="fa-solid fa-circle-check text-success me-1"></i>
                                @item.StockQuantity in stock
                            </p>
                        }
                        else
                        {
                            <p class="text-danger small mb-0">
                                <i class="fa-solid fa-circle-xmark me-1"></i>Out of stock
                            </p>
                        }
                        <p class="text-muted" style="font-size:.75rem">
                            Added @item.AddedOn.ToString("MMM d, yyyy")
                        </p>
                    </div>

                    <div class="card-footer bg-transparent border-0 d-flex gap-2">
                        @if (item.IsActive && item.StockQuantity > 0)
                        {
                            <form asp-controller="Cart" asp-action="Add" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <input type="hidden" name="quantity" value="1" />
                                <button type="submit" class="btn btn-sm btn-primary" title="Add to Cart">
                                    <i class="fa-solid fa-cart-plus"></i>
                                </button>
                            </form>
                        }
                        <form asp-controller="Favorite" asp-action="Remove" method="post" class="ms-auto">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <button type="submit" class="btn btn-sm btn-danger" title="Remove from Favourites">
                                <i class="fa-solid fa-heart-crack"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="text-center py-5">
        <i class="fa-solid fa-heart-crack fa-4x text-muted mb-3"></i>
        <h4 class="text-muted">No favourites yet</h4>
        <p class="text-secondary">Start browsing and add products you love.</p>
        <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary mt-2">
            <i class="fa-solid fa-shop me-1"></i>Go Shopping
        </a>
    </div>
}