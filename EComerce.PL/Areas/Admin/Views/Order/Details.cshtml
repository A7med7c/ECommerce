@model ECommerce.BLL.ViewModels.Order.OrderDetailsVM

@{
    ViewData["Title"] = $"Order {Model.OrderNumber}";
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-area="Admin" asp-controller="Order" asp-action="Index">All Orders</a>
        </li>
        <li class="breadcrumb-item active">@Model.OrderNumber</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">
        <i class="fa-solid fa-receipt me-2 text-primary"></i>Order <code>@Model.OrderNumber</code>
    </h2>
    <a asp-area="Admin" asp-controller="Order" asp-action="UpdateStatus"    asp-route-id="@Model.Id"
           class="btn btn-outline-secondary">
        <i class="fa-solid fa-pen-to-square me-1"></i>Update Status
    </a>
</div>

<div class="row g-4 mb-4">
    <!-- Status & Date -->
    <div class="col-md-6">
        <div class="card h-100 shadow-sm">
            <div class="card-header fw-semibold">
                <i class="fa-solid fa-circle-info me-2"></i>Order Info
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">
                        @{
                            var badgeClass = Model.Status switch
                            {
                                "Pending" => "bg-warning text-dark",
                                "Processing" => "bg-info text-dark",
                                "Shipped" => "bg-primary",
                                "Delivered" => "bg-success",
                                "Cancelled" => "bg-danger",
                                _ => "bg-secondary"
                            };
                        }
                        <span class="badge @badgeClass">@Model.Status</span>
                    </dd>
                    <dt class="col-sm-4">Date</dt>
                    <dd class="col-sm-8">@Model.OrderDate.ToString("dd MMM yyyy HH:mm")</dd>
                    <dt class="col-sm-4">Total</dt>
                    <dd class="col-sm-8 fw-bold">$@Model.TotalAmount.ToString("N2")</dd>
                </dl>
            </div>
        </div>
    </div>

    <!-- Shipping Address -->
    <div class="col-md-6">
        <div class="card h-100 shadow-sm">
            <div class="card-header fw-semibold">
                <i class="fa-solid fa-location-dot me-2"></i>Shipping Address
            </div>
            <div class="card-body">
                <address class="mb-0">
                    @Model.ShippingStreet<br />
                    @Model.ShippingCity, @Model.ShippingZip<br />
                    @Model.ShippingCountry
                </address>
            </div>
        </div>
    </div>
</div>

<!-- Order Items -->
<div class="card shadow-sm">
    <div class="card-header fw-semibold">
        <i class="fa-solid fa-box me-2"></i>Items (@Model.Items.Count())
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Product</th>
                        <th>SKU</th>
                        <th class="text-center">Qty</th>
                        <th class="text-end">Unit Price</th>
                        <th class="text-end">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.ProductName</td>
                            <td><code>@item.SKU</code></td>
                            <td class="text-center">@item.Quantity</td>
                            <td class="text-end">$@item.UnitPrice.ToString("N2")</td>
                            <td class="text-end">$@((item.Quantity * item.UnitPrice).ToString("N2"))</td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-light">
                    <tr>
                        <td colspan="4" class="text-end fw-bold">Total</td>
                        <td class="text-end fw-bold">$@Model.TotalAmount.ToString("N2")</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-area="Admin" asp-controller="Order" asp-action="Index" class="btn btn-secondary">
        <i class="fa-solid fa-arrow-left me-1"></i>Back to Orders
    </a>
</div>