@model ProductDetailsVM

@{
    ViewData["Title"] = "Product Details";
}

<h2>Product Details</h2>

<div class="card shadow-sm border-0 mb-3">
    <div class="card-body">
        <h4 class="mb-3">@Model.Name</h4>
        <p><strong>SKU:</strong> <span class="badge bg-light text-dark border">@Model.SKU</span></p>
        <p><strong>Price:</strong> <span class="text-success fw-bold fs-5">@Model.Price.ToString("C")</span></p>
        <p><strong>Stock:</strong>
            @if (Model.StockQuantity > 0)
            {
                <span class="text-success"><i class="fa-solid fa-circle-check me-1"></i>@Model.StockQuantity in stock</span>
            }
            else
            {
                <span class="text-danger"><i class="fa-solid fa-circle-xmark me-1"></i>Out of stock</span>
            }
        </p>
        <p><strong>Category:</strong> @Model.CategoryName</p>
        <p><strong>Status:</strong>
            <span class="badge @(Model.IsActive ? "bg-success" : "bg-secondary")">
                @(Model.IsActive ? "Active" : "Inactive")
            </span>
        </p>

        @if (Model.IsActive && Model.StockQuantity > 0)
        {
            <hr />
            <form asp-controller="Cart" asp-action="Add" method="post" class="d-flex align-items-center gap-2">
                @Html.AntiForgeryToken()
                <input type="hidden" name="productId" value="@Model.Id" />
                <div class="input-group" style="max-width:120px">
                    <span class="input-group-text">Qty</span>
                    <input type="number" name="quantity" value="1" min="1" max="@Model.StockQuantity"
                           class="form-control text-center" />
                </div>
                <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-cart-plus me-2"></i>Add to Cart
                </button>
            </form>
        }
        else
        {
            <hr />
            <button class="btn btn-secondary" disabled>
                <i class="fa-solid fa-ban me-2"></i>Unavailable
            </button>
        }
    </div>
</div>

<a asp-action="Index" class="btn btn-outline-secondary"><i class="fa-solid fa-arrow-left me-1"></i>Back To List</a>