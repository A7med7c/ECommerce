@model IEnumerable<ProductsVM>

@{
    ViewData["Title"] = "Products";
}

<h2>Products</h2>

<a asp-action="Create" class="btn btn-primary mb-3"><i class="fa-solid fa-plus me-1"></i>Create New</a>
@if (Model.Any())
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>@Html.DisplayNameFor(p => p.Name)</th>
                <th>@Html.DisplayNameFor(p => p.Price)</th>
                <th>@Html.DisplayNameFor(p => p.CategoryName)</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Price.ToString("C")</td>
                    <td>@item.CategoryName</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm"><i class="fa-solid fa-circle-info me-1"></i>Details</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm"><i class="fa-solid fa-pen-to-square me-1"></i>Edit</a>
                        <button type="button" class="btn btn-danger btn-sm delete-btn" data-id="@item.Id"><i class="fa-solid fa-trash me-1"></i>Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">
        There are no products available.
    </div>
}
<form id="deleteForm" asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="deleteId" />
</form>

