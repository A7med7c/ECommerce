@model IEnumerable<OrdersVM>

@{
    ViewData["Title"] = "Orders";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h2 class="mb-0">
        <i class="fa-solid fa-box-open me-2 text-primary"></i>Orders
    </h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fa-solid fa-plus me-1"></i>New Order
    </a>
</div>

@if (Model.Any())
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>@Html.DisplayNameFor(o => o.OrderNumber)</th>
                    <th>@Html.DisplayNameFor(o => o.Status)</th>
                    <th>@Html.DisplayNameFor(o => o.OrderDate)</th>
                    <th>@Html.DisplayNameFor(o => o.ShippingCity)</th>
                    <th class="text-end">@Html.DisplayNameFor(o => o.TotalAmount)</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td class="fw-semibold">
                            <i class="fa-solid fa-hashtag text-muted me-1"></i>@order.OrderNumber
                        </td>
                        <td>
                            @{
                                var badgeClass = order.Status switch
                                {
                                    "Pending" => "bg-warning text-dark",
                                    "Processing" => "bg-info text-dark",
                                    "Shipped" => "bg-primary",
                                    "Delivered" => "bg-success",
                                    "Cancelled" => "bg-secondary",
                                    _ => "bg-light text-dark"
                                };
                            }
                            <span class="badge @badgeClass">@order.Status</span>
                        </td>
                        <td>@order.OrderDate.ToString("dd MMM yyyy HH:mm")</td>
                        <td>@order.ShippingCity</td>
                        <td class="text-end fw-bold text-success">@order.TotalAmount.ToString("C")</td>
                        <td class="text-center text-nowrap">
                            <a asp-action="Details" asp-route-id="@order.Id"             class="btn btn-sm btn-info">
                                <i class="fa-solid fa-circle-info me-1"></i>Details
                            </a>
                            @if (order.Status != "Cancelled" && order.Status != "Delivered")
                            {
                                <button type="button"                     class="btn btn-sm btn-danger delete-btn"                        data-id="@order.Id"
                                        data-message="Order @order.OrderNumber will be cancelled!">
                                    <i class="fa-solid fa-ban me-1"></i>Cancel
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <form id="deleteForm" asp-action="Cancel" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" id="deleteId" />
    </form>
}
else
{
    <div class="text-center py-5">
        <i class="fa-solid fa-box-open fa-4x text-muted mb-4 d-block"></i>
        <h4 class="text-muted">No orders yet</h4>
        <p class="text-muted mb-4">Place your first order by browsing our products.</p>
        <a asp-controller="Product" asp-action="Index" class="btn btn-primary btn-lg">
            <i class="fa-solid fa-bag-shopping me-2"></i>Browse Products
        </a>
    </div>
}