@model ECommerce.PL.ViewModels.ProfileVM

@{
    ViewData["Title"] = "My Profile";
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-8">

        <!-- Profile Header -->
        <div class="card mb-4" style="border:none;border-radius:var(--shop-radius);overflow:hidden">
            <div class="card-body p-0">
                <div style="background:linear-gradient(135deg,var(--shop-primary),#3b82f6);padding:2rem;color:#fff">
                    <div class="d-flex align-items-center gap-3">
                        <div style="width:72px;height:72px;border-radius:50%;background:rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;font-size:2rem;font-weight:700">
                            @(Model.FullName?.Substring(0, 1).ToUpper() ?? "U")
                        </div>
                        <div>
                            <h3 class="mb-0 fw-bold">@Model.FullName</h3>
                            <span style="opacity:.85">@Model.Email</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Profile Details -->
        <div class="card mb-4" style="border:none;border-radius:var(--shop-radius)">
            <div class="card-header d-flex justify-content-between align-items-center"
                 style="background:#f8fafc;border-bottom:1px solid #e2e8f0">
                <h5 class="mb-0 fw-semibold">
                    <i class="fa-solid fa-user me-2 text-primary"></i>Personal Information
                </h5>
                <a asp-action="Edit" class="btn btn-sm btn-outline-primary">
                    <i class="fa-solid fa-pen-to-square me-1"></i>Edit Profile
                </a>
            </div>
            <div class="card-body p-4">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label text-muted small mb-1">
                            <i class="fa-solid fa-user me-1"></i>Full Name
                        </label>
                        <p class="fw-medium mb-0">@Model.FullName</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted small mb-1">
                            <i class="fa-solid fa-envelope me-1"></i>Email Address
                        </label>
                        <p class="fw-medium mb-0">@Model.Email</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted small mb-1">
                            <i class="fa-solid fa-phone me-1"></i>Phone Number
                        </label>
                        <p class="fw-medium mb-0">@(Model.PhoneNumber ?? "Not provided")</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Address -->
        <div class="card mb-4" style="border:none;border-radius:var(--shop-radius)">
            <div class="card-header d-flex justify-content-between align-items-center"
                 style="background:#f8fafc;border-bottom:1px solid #e2e8f0">
                <h5 class="mb-0 fw-semibold">
                    <i class="fa-solid fa-location-dot me-2 text-primary"></i>Default Address
                </h5>
                <a asp-action="Edit" class="btn btn-sm btn-outline-primary">
                    <i class="fa-solid fa-pen-to-square me-1"></i>Edit
                </a>
            </div>
            <div class="card-body p-4">
                @if (!string.IsNullOrWhiteSpace(Model.Street) || !string.IsNullOrWhiteSpace(Model.City))
                {
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label text-muted small mb-1">Street</label>
                            <p class="fw-medium mb-0">@(Model.Street ?? "—")</p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted small mb-1">City</label>
                            <p class="fw-medium mb-0">@(Model.City ?? "—")</p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted small mb-1">Country</label>
                            <p class="fw-medium mb-0">@(Model.Country ?? "—")</p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted small mb-1">Zip Code</label>
                            <p class="fw-medium mb-0">@(Model.Zip ?? "—")</p>
                        </div>
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">
                        <i class="fa-solid fa-circle-info me-1"></i>No address on file.
                        <a asp-action="Edit">Add one now</a>.
                    </p>
                }
            </div>
        </div>

        <!-- Security -->
        <div class="card mb-4" style="border:none;border-radius:var(--shop-radius)">
            <div class="card-header d-flex justify-content-between align-items-center"
                 style="background:#f8fafc;border-bottom:1px solid #e2e8f0">
                <h5 class="mb-0 fw-semibold">
                    <i class="fa-solid fa-shield-halved me-2 text-primary"></i>Security
                </h5>
            </div>
            <div class="card-body p-4">
                <a asp-action="ChangePassword" class="btn btn-outline-warning">
                    <i class="fa-solid fa-key me-1"></i>Change Password
                </a>
            </div>
        </div>

    </div>
</div>
