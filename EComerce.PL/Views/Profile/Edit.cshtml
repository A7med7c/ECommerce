@model ECommerce.PL.ViewModels.ProfileVM

@{
    ViewData["Title"] = "Edit Profile";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8 col-lg-6">

        <div class="auth-card card">
            <div class="auth-header" style="background:linear-gradient(135deg,var(--shop-primary),#3b82f6);color:#fff">
                <div class="mb-2" style="font-size:2.5rem">
                    <i class="fa-solid fa-user-pen"></i>
                </div>
                <h4 class="mb-0 fw-bold">Edit Profile</h4>
                <p class="mb-0 mt-1" style="font-size:.875rem;opacity:.85">Update your personal information</p>
            </div>
            <div class="card-body p-4">

                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <form asp-action="Edit" method="post">

                    
                    <h6 class="fw-semibold text-muted mb-3">
                        <i class="fa-solid fa-user me-1"></i>Personal Information
                    </h6>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label">
                            <i class="fa-solid fa-user me-1 text-muted"></i>Full Name
                        </label>
                        <input asp-for="FullName" class="form-control" placeholder="Your full name" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">
                            <i class="fa-solid fa-envelope me-1 text-muted"></i>Email Address
                        </label>
                        <input asp-for="Email" class="form-control" readonly
                               style="background:#f1f5f9;cursor:not-allowed" />
                        <span class="text-muted small">Email cannot be changed.</span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="PhoneNumber" class="form-label">
                            <i class="fa-solid fa-phone me-1 text-muted"></i>Phone Number
                        </label>
                        <input asp-for="PhoneNumber" class="form-control" placeholder="+1 (555) 123-4567" />
                        <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                    </div>

                    
                    <h6 class="fw-semibold text-muted mb-3">
                        <i class="fa-solid fa-location-dot me-1"></i>Default Address
                    </h6>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Country" class="form-label">Country</label>
                            <input asp-for="Country" class="form-control" placeholder="Country" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="City" class="form-label">City</label>
                            <input asp-for="City" class="form-control" placeholder="City" />
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-8">
                            <label asp-for="Street" class="form-label">Street</label>
                            <input asp-for="Street" class="form-control" placeholder="Street address" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Zip" class="form-label">Zip Code</label>
                            <input asp-for="Zip" class="form-control" placeholder="Zip" />
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fa-solid fa-floppy-disk me-1"></i>Save Changes
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="fa-solid fa-xmark me-1"></i>Cancel
                        </a>
                    </div>
                </form>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
