@model UpdateCategoryVM

<div class="row justify-content-center mt-4">
    <div class="col-6">

        <h2 class="mb-4">Edit Category</h2>

        <form asp-action="Edit"
              asp-route-id="@Model.CategoryId"
              method="post">


            <input type="hidden"
                   asp-for="CategoryId" />

            <!-- Name -->
            <div class="mb-3">
                <label asp-for="Name"
                       class="form-label"></label>

                <input asp-for="Name"
                       class="form-control" />

                <span asp-validation-for="Name"
                      class="text-danger"></span>
            </div>

            <!-- Parent Category -->
            <div class="mb-3">
                <label class="form-label">
                    Parent Category
                </label>

                <select asp-for="ParentCategoryId"
                        class="form-select">

                    <option value="">
                        -- Main Category --
                    </option>

                    @foreach (var category in Model.ParentCategories)
                    {
                        <option value="@category.Id">
                            @category.Name
                        </option>
                    }

                </select>
            </div>

            <button type="submit"
                    class="btn btn-success">
                Update
            </button>

            <a asp-action="Index"
               class="btn btn-outline-secondary">
                Back
            </a>

        </form>

    </div>
</div>