@model IEnumerable<CategoriesVM>

@{
    ViewData["Title"] = "Admin – Categories";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h2 class="mb-0">
        <i class="fa-solid fa-tags me-2 text-primary"></i>Categories
    </h2>
    <a asp-area="Admin" asp-action="Create" class="btn btn-primary">
        <i class="fa-solid fa-plus me-1"></i>Create New Category
    </a>
</div>

@if (Model.Any())
{
    <table class="table table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>@Html.DisplayNameFor(d => d.Name)</th>
                <th>@Html.DisplayNameFor(d => d.CreatedAt )</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var category in Model)
            {
                <tr>
                    <td>@category.Name</td>
                    <td>@category.CreatedAt .ToString("dd MMM yyyy")</td>
                    <td class="text-center text-nowrap">
                        <a asp-area="Admin" asp-action="Details" asp-route-id="@category.Id" class="btn btn-sm btn-info">
                            <i class="fa-solid fa-circle-info"></i>
                        </a>
                        <a asp-area="Admin" asp-action="Edit" asp-route-id="@category.Id" class="btn btn-sm btn-warning">
                            <i class="fa-solid fa-pen-to-square"></i>
                        </a>
                        <a asp-area="Admin" asp-controller="Category" asp-action="Delete" asp-route-id="@category.Id"
                               class="btn btn-sm btn-danger">
                            <i class="fa-solid fa-trash"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">No categories found.</div>
}