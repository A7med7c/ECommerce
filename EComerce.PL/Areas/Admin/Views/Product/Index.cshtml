@model ProductListVM

@{
    ViewData["Title"] = "Admin - Products";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h2 class="mb-0">
        <i class="fa-solid fa-boxes-stacked me-2 text-primary"></i>Products
    </h2>
    <a asp-area="Admin" asp-action="Create" class="btn btn-primary">
        <i class="fa-solid fa-plus me-1"></i>Create New
    </a>
</div>

<!-- Search / filter bar -->
<div class="card shadow-sm border-0 mb-3">
    <div class="card-body py-2">
        <form asp-area="Admin" asp-action="Index" method="get" class="row g-2 align-items-end">
            <div class="col-sm-5">
                <div class="input-group">
                    <input type="text" name="q" value="@Model.Q" class="form-control"
                           placeholder="Search by name or SKU..." />
                    <button class="btn btn-outline-secondary" type="submit">
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </button>
                </div>
            </div>
            <div class="col-sm-3">
                <select name="categoryId" class="form-select" onchange="this.form.submit()"
                        asp-items="@(new SelectList(Model.Categories, nameof(CategoryFilterVM.Id), nameof(CategoryFilterVM.Name), Model.CategoryId))">
                    <option value="">All Categories</option>
                </select>
            </div>
            <div class="col-sm-2">
                <select name="sort" class="form-select" onchange="this.form.submit()"
                        asp-items="@(new SelectList(new[]
                        {
                            new { Value = "newest",     Text = "Newest" },
                            new { Value = "price_asc",  Text = "Price Asc" },
                            new { Value = "price_desc", Text = "Price Desc" }
                        }, "Value", "Text", Model.Sort))">
                </select>
            </div>
            @if (!string.IsNullOrEmpty(Model.Q) || Model.CategoryId.HasValue)
            {
                <div class="col-sm-2">
                    <a asp-area="Admin" asp-action="Index" class="btn btn-outline-danger w-100">
                        <i class="fa-solid fa-xmark me-1"></i>Clear
                    </a>
                </div>
            }
        </form>
    </div>
</div>

<p class="text-muted small">
    Showing <strong>@Model.Products.Count</strong> of <strong>@Model.TotalCount</strong> products
</p>

@if (Model.Products.Any())
{
    <div class="table-responsive">
        <table class="table table-hover table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th style="width:60px">Image</th>
                    <th>Name</th>
                    <th>SKU</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Category</th>
                    <th>Active</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Products)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="@item.Name"
                                     class="rounded object-fit-cover" style="width:50px;height:50px" />
                            }
                            else
                            {
                                <div class="bg-light rounded d-flex align-items-center justify-content-center"
                                     style="width:50px;height:50px">
                                    <i class="fa-solid fa-image text-muted"></i>
                                </div>
                            }
                        </td>
                        <td class="fw-semibold">@item.Name</td>
                        <td><span class="badge bg-light text-dark border">@item.SKU</span></td>
                        <td class="text-success fw-bold">@item.Price.ToString("C")</td>
                        <td>@item.StockQuantity</td>
                        <td>@item.CategoryName</td>
                        <td>
                            <span class="badge @(item.IsActive ? "bg-success" : "bg-secondary")">
                                @(item.IsActive ? "Yes" : "No")
                            </span>
                        </td>
                        <td class="text-center text-nowrap">
                            <a asp-area="Admin" asp-action="Details" asp-route-id="@item.Id"
                               class="btn btn-info btn-sm">
                                <i class="fa-solid fa-circle-info me-1"></i>Details
                            </a>
                            <a asp-area="Admin" asp-action="Edit" asp-route-id="@item.Id"
                               class="btn btn-warning btn-sm">
                                <i class="fa-solid fa-pen-to-square me-1"></i>Edit
                            </a>
                            <button type="button" class="btn btn-danger btn-sm delete-btn"
                                    data-id="@item.Id"
                                    data-message="Product &lsquo;@item.Name&rsquo; will be permanently deleted!">
                                <i class="fa-solid fa-trash me-1"></i>Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link" asp-area="Admin" asp-action="Index"
                       asp-route-q="@Model.Q" asp-route-sort="@Model.Sort"
                       asp-route-categoryId="@Model.CategoryId"
                       asp-route-page="@(Model.CurrentPage - 1)">
                        <i class="fa-solid fa-chevron-left"></i>
                    </a>
                </li>
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-area="Admin" asp-action="Index"
                           asp-route-q="@Model.Q" asp-route-sort="@Model.Sort"
                           asp-route-categoryId="@Model.CategoryId"
                           asp-route-page="@i">@i</a>
                    </li>
                }
                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                    <a class="page-link" asp-area="Admin" asp-action="Index"
                       asp-route-q="@Model.Q" asp-route-sort="@Model.Sort"
                       asp-route-categoryId="@Model.CategoryId"
                       asp-route-page="@(Model.CurrentPage + 1)">
                        <i class="fa-solid fa-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
}
else
{
    <div class="alert alert-info">No products found.</div>
}

<form id="deleteForm" asp-area="Admin" asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="deleteId" />
</form>
