@model ECommerce.PL.ViewModels.ChangePasswordVM

@{
    ViewData["Title"] = "Change Password";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6 col-lg-5">

        <div class="auth-card card">
            <div class="auth-header" style="background:linear-gradient(135deg,#f59e0b,#d97706);color:#fff">
                <div class="mb-2" style="font-size:2.5rem">
                    <i class="fa-solid fa-key"></i>
                </div>
                <h4 class="mb-0 fw-bold">Change Password</h4>
                <p class="mb-0 mt-1" style="font-size:.875rem;opacity:.85">Keep your account secure</p>
            </div>
            <div class="card-body p-4">

                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <form asp-action="ChangePassword" method="post">

                    <div class="mb-3">
                        <label asp-for="OldPassword" class="form-label">
                            <i class="fa-solid fa-lock me-1 text-muted"></i>Current Password
                        </label>
                        <input asp-for="OldPassword" class="form-control" placeholder="Enter current password"
                               autocomplete="current-password" />
                        <span asp-validation-for="OldPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label">
                            <i class="fa-solid fa-lock me-1 text-muted"></i>New Password
                        </label>
                        <input asp-for="NewPassword" class="form-control" placeholder="Min 8 characters"
                               autocomplete="new-password" />
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmNewPassword" class="form-label">
                            <i class="fa-solid fa-lock me-1 text-muted"></i>Confirm New Password
                        </label>
                        <input asp-for="ConfirmNewPassword" class="form-control" placeholder="Repeat new password"
                               autocomplete="new-password" />
                        <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning">
                            <i class="fa-solid fa-key me-1"></i>Change Password
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="fa-solid fa-xmark me-1"></i>Cancel
                        </a>
                    </div>
                </form>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
