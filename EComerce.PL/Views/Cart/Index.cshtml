@model CartVM

@{
    ViewData["Title"] = "Shopping Cart";
}

<!-- Page Header -->
<div class="d-flex align-items-center justify-content-between mb-4">
    <h2 class="section-title mb-0">
        <i class="fa-solid fa-cart-shopping me-2" style="color:var(--shop-primary)"></i>Shopping Cart
    </h2>
    @if (!Model.IsEmpty)
    {
        <form asp-action="Clear" asp-controller="Cart" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-danger btn-sm"
                    onclick="return confirm('Clear the entire cart?')">
                <i class="fa-solid fa-trash me-1"></i>Clear Cart
            </button>
        </form>
    }
</div>

@if (Model.IsEmpty)
{
    <div class="empty-state">
        <div class="empty-icon"><i class="fa-solid fa-cart-shopping"></i></div>
        <h4>Your cart is empty</h4>
        <p>Looks like you have not added anything yet.</p>
        <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary btn-lg">
            <i class="fa-solid fa-shop me-2"></i>Browse Products
        </a>
    </div>
}
else
{
    <div class="row g-4">

        <!-- Cart Items -->
        <div class="col-lg-8">
            <div class="card">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th class="ps-4" style="width:40%">Product</th>
                                    <th class="text-end">Unit Price</th>
                                    <th class="text-center">Quantity</th>
                                    <th class="text-end">Total</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Items)
                                {
                                    <tr id="row-@item.ProductId">
                                        <td class="ps-4">
                                            <div>
                                                <p class="fw-semibold mb-0" style="font-size:.9rem">@item.ProductName</p>
                                                <span class="badge bg-light text-muted border" style="font-size:.7rem">@item.SKU</span>
                                            </div>
                                        </td>
                                        <td class="text-end text-muted">@item.UnitPrice.ToString("C")</td>
                                        <td class="text-center" style="min-width:160px">
                                            <div class="d-flex align-items-center justify-content-center gap-1">
                                                <form asp-action="Update" asp-controller="Cart" method="post" class="m-0">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                                    <input type="hidden" name="quantity" value="@(item.Quantity - 1)" />
                                                    <button type="submit" class="btn btn-outline-secondary btn-sm px-2"
                                                            title="@(item.Quantity == 1 ? "Remove item" : "Decrease")">
                                                        <i class="fa-solid @(item.Quantity == 1 ? "fa-trash" : "fa-minus")" style="font-size:.7rem"></i>
                                                    </button>
                                                </form>
                                                <span class="qty-badge">@item.Quantity</span>
                                                <form asp-action="Update" asp-controller="Cart" method="post" class="m-0">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                                    <input type="hidden" name="quantity" value="@(item.Quantity + 1)" />
                                                    <button type="submit" class="btn btn-outline-secondary btn-sm px-2"
                                                            title="Increase"
                                                            @(item.Quantity >= item.StockQuantity ? "disabled" : "")>
                                                        <i class="fa-solid fa-plus" style="font-size:.7rem"></i>
                                                    </button>
                                                </form>
                                            </div>
                                            <div class="text-muted mt-1" style="font-size:.75rem">@item.StockQuantity in stock</div>
                                        </td>
                                        <td class="text-end fw-bold" style="color:var(--shop-primary)">
                                            @item.LineTotal.ToString("C")
                                        </td>
                                        <td class="text-center pe-3">
                                            <form asp-action="Remove" asp-controller="Cart" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="productId" value="@item.ProductId" />
                                                <button type="submit" class="btn btn-outline-danger btn-sm" title="Remove">
                                                    <i class="fa-solid fa-xmark"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="mt-3">
                <a asp-controller="Catalog" asp-action="Index" class="btn btn-outline-secondary">
                    <i class="fa-solid fa-arrow-left me-2"></i>Continue Shopping
                </a>
            </div>
        </div>

        <!-- Order Summary -->
        <div class="col-lg-4">
            <div class="card order-summary-card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fa-solid fa-receipt me-2"></i>Order Summary</h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="d-flex justify-content-between py-2 border-bottom">
                            <span class="text-muted">Items (@Model.TotalItems)</span>
                            <span class="fw-semibold">@Model.SubTotal.ToString("C")</span>
                        </li>
                        <li class="d-flex justify-content-between py-2 border-bottom">
                            <span class="text-muted">Shipping</span>
                            <span class="fw-semibold text-success">Free</span>
                        </li>
                        <li class="d-flex justify-content-between py-3">
                            <span class="fw-bold fs-6">Total</span>
                            <span class="fw-bold fs-5" style="color:var(--shop-primary)">@Model.SubTotal.ToString("C")</span>
                        </li>
                    </ul>
                </div>
                <div class="card-footer" style="background:transparent;border-top:1px solid var(--shop-border)">
                    <a asp-controller="Order" asp-action="Create" class="btn btn-primary w-100 btn-lg">
                        <i class="fa-solid fa-lock me-2"></i>Proceed to Checkout
                    </a>
                    <p class="text-muted text-center small mt-2 mb-0">
                        <i class="fa-solid fa-shield-halved me-1"></i>Secure &amp; encrypted checkout
                    </p>
                </div>
            </div>
        </div>

    </div>
}
