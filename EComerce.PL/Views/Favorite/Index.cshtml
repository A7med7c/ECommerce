@model IEnumerable<FavoriteVM>

@{
    ViewData["Title"] = "My Favourites";
}

<!-- Page Header -->
<div class="d-flex align-items-center justify-content-between mb-4">
    <h2 class="section-title mb-0">
        <i class="fa-solid fa-heart text-danger me-2"></i>My Favourites
    </h2>
    <a asp-controller="Catalog" asp-action="Index" class="btn btn-outline-primary">
        <i class="fa-solid fa-shop me-1"></i>Browse Shop
    </a>
</div>

@if (Model.Any())
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="product-card h-100 d-flex flex-column">
                    <div class="img-wrapper">
                        <a asp-controller="Catalog" asp-action="Details" asp-route-id="@item.ProductId">
                            @if (!string.IsNullOrEmpty(item.ProductImageUrl))
                            {
                                <img src="@item.ProductImageUrl" alt="@item.ProductName" class="card-img-top" />
                            }
                            else
                            {
                                <div class="bg-light d-flex align-items-center justify-content-center" style="height:220px">
                                    <i class="fa-solid fa-image fa-3x text-muted"></i>
                                </div>
                            }
                        </a>
                    </div>
                    <div class="card-body d-flex flex-column px-3 pt-3 pb-2">
                        <span class="cat-badge mb-2">@item.CategoryName</span>
                        <h6 class="card-title fw-semibold mb-1" style="font-size:.875rem;line-height:1.4">
                            @item.ProductName
                        </h6>
                        <div class="product-rating mb-2">
                            <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star-half-stroke"></i>
                            <span class="rating-count">(4.5)</span>
                        </div>
                        <p class="product-price mt-auto mb-1">@item.ProductPrice.ToString("C")</p>
                        @if (item.StockQuantity > 0)
                        {
                            <p class="stock-ok mb-0"><i class="fa-solid fa-circle-check me-1"></i>In stock</p>
                        }
                        else
                        {
                            <p class="stock-out mb-0"><i class="fa-solid fa-circle-xmark me-1"></i>Out of stock</p>
                        }
                        <p class="text-muted mt-1 mb-0" style="font-size:.75rem">
                            Added @item.AddedOn.ToString("MMM d, yyyy")
                        </p>
                    </div>
                    <div class="card-footer d-flex gap-2">
                        @if (item.IsActive && item.StockQuantity > 0)
                        {
                            <form asp-controller="Cart" asp-action="Add" method="post" class="d-inline flex-grow-1">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <input type="hidden" name="quantity" value="1" />
                                <button type="submit" class="btn btn-sm btn-primary w-100">
                                    <i class="fa-solid fa-cart-plus me-1"></i>Add to Cart
                                </button>
                            </form>
                        }
                        <form asp-controller="Favorite" asp-action="Remove" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Remove from Favourites">
                                <i class="fa-solid fa-heart-crack"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="empty-state">
        <div class="empty-icon"><i class="fa-solid fa-heart"></i></div>
        <h4>No favourites yet</h4>
        <p>Start browsing and save products you love.</p>
        <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary btn-lg">
            <i class="fa-solid fa-shop me-2"></i>Go Shopping
        </a>
    </div>
}
