@model ProductListVM

@{
    ViewData["Title"] = "Home";
}

<!-- HERO SECTION -->
<div class="hero-section">
    <div class="container">
        <div class="hero-content">
            <div class="row align-items-center">
                <div class="col-lg-7">
                    <h1 class="hero-title">Shop Smart,<br />Shop Better</h1>
                    <p class="hero-subtitle">
                        Discover premium products at unbeatable prices. From electronics to fashion, find everything you need.
                    </p>
                    <form class="hero-search d-flex" asp-controller="Catalog" asp-action="Index" method="get">
                        <div class="input-group">
                            <input type="search" name="q" class="form-control" placeholder="What are you looking for?" />
                            <button class="btn" type="submit">
                                <i class="fa-solid fa-magnifying-glass me-1"></i> Search
                            </button>
                        </div>
                    </form>
                    <div class="hero-stats">
                        <div class="hero-stat">
                            <span class="stat-number">@Model.TotalCount+</span>
                            <span class="stat-label">Products</span>
                        </div>
                        <div class="hero-stat">
                            <span class="stat-number">@Model.Categories.Count</span>
                            <span class="stat-label">Categories</span>
                        </div>
                        <div class="hero-stat">
                            <span class="stat-number">Free</span>
                            <span class="stat-label">Shipping</span>
                        </div>
                    </div>
                </div>
                <div class="col-lg-5 d-none d-lg-flex justify-content-center">
                    <div style="font-size:12rem;opacity:.15">
                        <i class="fa-solid fa-bag-shopping"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- TRUST BAR -->
<div class="trust-bar mb-4">
    <div class="trust-item"><i class="fa-solid fa-truck-fast"></i><span>Free Shipping</span></div>
    <div class="trust-item"><i class="fa-solid fa-shield-halved"></i><span>Secure Payment</span></div>
    <div class="trust-item"><i class="fa-solid fa-rotate-left"></i><span>Easy Returns</span></div>
    <div class="trust-item"><i class="fa-solid fa-headset"></i><span>24/7 Support</span></div>
</div>

<!-- BROWSE BY CATEGORY -->
<div class="home-section">
    <div class="section-header">
        <h2><i class="fa-solid fa-layer-group me-2" style="color:var(--shop-primary)"></i>Browse by Category</h2>
        <a asp-controller="Catalog" asp-action="Index" class="view-all">View All <i class="fa-solid fa-arrow-right ms-1"></i></a>
    </div>
    <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-6 g-3">
        @foreach (var cat in Model.Categories)
        {
            <div class="col">
                <a asp-controller="Catalog" asp-action="Index" asp-route-categoryId="@cat.Id" class="category-card">
                    <div class="cat-icon">
                        @{
                            var catName = cat.Name.ToLower();
                            var icon = "fa-solid fa-box";
                            if (catName.Contains("electron")) { icon = "fa-solid fa-microchip"; }
                            else if (catName.Contains("fashion") || catName.Contains("cloth")) { icon = "fa-solid fa-shirt"; }
                            else if (catName.Contains("home") || catName.Contains("furniture")) { icon = "fa-solid fa-couch"; }
                            else if (catName.Contains("sport")) { icon = "fa-solid fa-basketball"; }
                            else if (catName.Contains("toy") || catName.Contains("game")) { icon = "fa-solid fa-gamepad"; }
                            else if (catName.Contains("beauty") || catName.Contains("health")) { icon = "fa-solid fa-spa"; }
                            else if (catName.Contains("book")) { icon = "fa-solid fa-book"; }
                            else if (catName.Contains("food") || catName.Contains("grocer")) { icon = "fa-solid fa-utensils"; }
                        }
                        <i class="@icon"></i>
                    </div>
                    <div class="cat-name">@cat.Name</div>
                </a>
            </div>
        }
    </div>
</div>

<!-- FEATURED PRODUCTS -->
<div class="home-section">
    <div class="section-header">
        <h2><i class="fa-solid fa-fire me-2" style="color:#f59e0b"></i>Featured Products</h2>
        <a asp-controller="Catalog" asp-action="Index" class="view-all">View All <i class="fa-solid fa-arrow-right ms-1"></i></a>
    </div>

    @if (Model.Products.Any())
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
            @foreach (var product in Model.Products)
            {
                <div class="col">
                    <div class="product-card h-100 d-flex flex-column">
                        <div class="img-wrapper">
                            <a asp-controller="Catalog" asp-action="Details" asp-route-id="@product.Id">
                                @if (!string.IsNullOrEmpty(product.ImageUrl))
                                {
                                    <img src="@product.ImageUrl" alt="@product.Name" class="card-img-top" />
                                }
                                else
                                {
                                    <div class="bg-light d-flex align-items-center justify-content-center" style="height:220px">
                                        <i class="fa-solid fa-image fa-3x text-muted"></i>
                                    </div>
                                }
                            </a>
                        </div>
                        <div class="card-body d-flex flex-column px-3 pt-3 pb-2">
                            <span class="cat-badge mb-2">@product.CategoryName</span>
                            <h6 class="card-title fw-semibold mb-1" style="font-size:.875rem;line-height:1.4">
                                <a asp-controller="Catalog" asp-action="Details" asp-route-id="@product.Id"
                                   class="text-decoration-none text-dark stretched-link">@product.Name</a>
                            </h6>
                            <div class="product-rating mb-2">
                                <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star-half-stroke"></i>
                                <span class="rating-count">(4.5)</span>
                            </div>
                            <p class="product-price mt-auto mb-1">@product.Price.ToString("C")</p>
                            @if (product.StockQuantity > 0)
                            {
                                <p class="stock-ok mb-0"><i class="fa-solid fa-circle-check me-1"></i>@product.StockQuantity in stock</p>
                            }
                            else
                            {
                                <p class="stock-out mb-0"><i class="fa-solid fa-circle-xmark me-1"></i>Out of stock</p>
                            }
                        </div>
                        <div class="card-footer d-flex gap-2 position-relative" style="z-index:1">
                            @if (product.IsActive && product.StockQuantity > 0)
                            {
                                <form asp-controller="Cart" asp-action="Add" method="post" class="d-inline flex-grow-1" data-async="cart">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@product.Id" />
                                    <input type="hidden" name="quantity" value="1" />
                                    <button type="submit" class="btn btn-sm btn-primary w-100">
                                        <i class="fa-solid fa-cart-plus me-1"></i>Add to Cart
                                    </button>
                                </form>
                            }
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <form asp-controller="Favorite" asp-action="Add" method="post" data-async="favorite">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@product.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Add to Favourites">
                                        <i class="fa-solid fa-heart"></i>
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="text-center mt-4">
            <a asp-controller="Catalog" asp-action="Index" class="btn btn-outline-primary btn-lg px-5">
                <i class="fa-solid fa-shop me-2"></i>Browse All Products
            </a>
        </div>
    }
    else
    {
        <div class="alert alert-info d-flex align-items-center gap-2">
            <i class="fa-solid fa-circle-info fa-lg"></i>
            <div>No products available yet. Check back soon!</div>
        </div>
    }
</div>
