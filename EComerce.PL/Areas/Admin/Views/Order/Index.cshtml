@model IEnumerable<ECommerce.BLL.ViewModels.Order.AdminOrdersVM>

@{
    ViewData["Title"] = "All Orders";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="fa-solid fa-list-check me-2 text-primary"></i>All Orders</h2>
</div>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fa-solid fa-circle-check me-2"></i>@success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fa-solid fa-circle-exclamation me-2"></i>@error
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Order #</th>
                        <th>Customer</th>
                        <th>Email</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th class="text-end">Total</th>
                        <th>City</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td><code>@order.OrderNumber</code></td>
                            <td>@order.UserFullName</td>
                            <td>@order.UserEmail</td>
                            <td>
                                @{
                                    var badgeClass = order.Status switch
                                    {
                                        "Pending" => "bg-warning text-dark",
                                        "Processing" => "bg-info text-dark",
                                        "Shipped" => "bg-primary",
                                        "Delivered" => "bg-success",
                                        "Cancelled" => "bg-danger",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @badgeClass">@order.Status</span>
                            </td>
                            <td>@order.OrderDate.ToString("dd MMM yyyy")</td>
                            <td class="text-end">$@order.TotalAmount.ToString("N2")</td>
                            <td>@order.ShippingCity</td>
                            <td class="text-center">
                                <a asp-area="Admin" asp-controller="Order" asp-action="Details"                                  asp-route-id="@order.Id"
                                       class="btn btn-sm btn-outline-primary me-1" title="Details">
                                    <i class="fa-solid fa-eye"></i>
                                </a>
                                <a asp-area="Admin" asp-controller="Order" asp-action="UpdateStatus"
                                       asp-route-id="@order.Id"    class="btn btn-sm btn-outline-secondary" title="Update Status">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                <i class="fa-solid fa-inbox fa-2x d-block mb-2"></i>No orders yet.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>