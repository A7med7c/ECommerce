@model IEnumerable<CategoriesVM>

@{
    ViewData["Title"] = "Categories";
}

<h2 class="mb-3">
    <a class="btn btn-primary" asp-action="Create">
        <i class="fa-solid fa-plus me-1"></i>
        Create New Category
    </a>
</h2>

@if (Model.Any())
{
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>@Html.DisplayNameFor(d => d.Name)</th>
                <th>@Html.DisplayNameFor(d => d.CreatedAt )</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var category in Model)
            {
                <tr>
                    <td>@category.Name</td>
                    <td>@category.CreatedAt </td>

                    <td class="text-center">

                        
                        <a class="btn btn-sm btn-primary"                         asp-action="Details"   asp-route-id="@category.Id">
                            <i class="fa-solid fa-circle-info"></i>
                        </a>

                        
                        <a class="btn btn-sm btn-success"              asp-action="Edit"                 asp-route-id="@category.Id">
                            <i class="fa-solid fa-pen-to-square"></i>
                        </a>

                        
                        <a href="#"   class="btn btn-sm btn-danger delete-btn"      data-id="@category.Id"
                               data-message="Category &lsquo;@category.Name&rsquo; will be permanently deleted!">
                            <i class="fa-solid fa-trash"></i>
                        </a>

                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">
        There are no categories available.
    </div>
}

<form id="deleteForm" asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="deleteId" />
</form>