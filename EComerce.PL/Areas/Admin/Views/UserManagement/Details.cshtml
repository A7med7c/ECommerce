@model ECommerce.DAL.Entities.IdentityModule.ApplicationUser

@{
    ViewData["Title"] = "Admin - User Details";
    var userRoles = ViewBag.Roles as IList<string> ?? new List<string>();
    var allRoles = new[] { "Admin", "Customer" };
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">

        <h2 class="mb-4">Manage User Roles</h2>

        <div class="card mb-4">
            <div class="card-body">
                <h5 class="fw-bold">@Model.FullName</h5>
                <p class="text-muted mb-1">@Model.Email</p>
                <div class="mt-2">
                    <strong>Current Roles:</strong>
                    @if (userRoles.Any())
                    {
                        foreach (var r in userRoles)
                        {
                            <span class="badge bg-primary me-1">@r</span>
                        }
                    }
                    else
                    {
                        <span class="text-muted">No roles assigned</span>
                    }
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header fw-semibold">Assign / Revoke Role</div>
            <div class="card-body">
                <div class="row g-3">
                    @foreach (var role in allRoles)
                    {
                        <div class="col-auto">
                            @if (userRoles.Contains(role))
                            {
                                <form asp-area="Admin" asp-controller="UserManagement"                    asp-action="RevokeRole" method="post"
                                      class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@Model.Id" />
                                    <input type="hidden" name="role" value="@role" />
                                    <button type="submit" class="btn btn-sm btn-danger">Revoke @role</button>
                                </form>
                            }
                            else
                            {
                                <form asp-area="Admin" asp-controller="UserManagement"                                  asp-action="AssignRole" method="post"
                                      class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@Model.Id" />
                                    <input type="hidden" name="role" value="@role" />
                                    <button type="submit" class="btn btn-sm btn-success">Assign @role</button>
                                </form>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="mt-3">
            <a asp-area="Admin" asp-controller="UserManagement" asp-action="Index"
               class="btn btn-outline-secondary">Back to Users</a>
        </div>

    </div>
</div>