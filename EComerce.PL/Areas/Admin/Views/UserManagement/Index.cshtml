@model IEnumerable<ECommerce.PL.ViewModels.UserWithRoleViewModel>

@{
    ViewData["Title"] = "Admin - User Management";
    var allRoles = new[] { "Admin", "Customer" };
    int totalUsers = Model.Count();
    int activeCount = Model.Count(u => u.IsActive);
    int inactiveCount = totalUsers - activeCount;
}

<div class="row g-3 mb-4">
    <div class="col-sm-4">
        <div class="card text-center p-3">
            <h3 class="fw-bold text-primary mb-1">@totalUsers</h3>
            <small class="text-muted">Total Users</small>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card text-center p-3">
            <h3 class="fw-bold text-success mb-1">@activeCount</h3>
            <small class="text-muted">Active</small>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card text-center p-3">
            <h3 class="fw-bold text-danger mb-1">@inactiveCount</h3>
            <small class="text-muted">Inactive</small>
        </div>
    </div>
</div>

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h2 class="mb-1">User Management</h2>
        <p class="text-muted mb-0">Manage users, roles, and account status</p>
    </div>
</div>

@if (TempData["Error"] is string errorMessage)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<p class="text-muted small mb-3">Showing <strong>@totalUsers</strong> users</p>

@if (Model.Any())
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>User</th>
                    <th>Role</th>
                    <th class="text-center">Status</th>
                    <th>Assign Role</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    var badgeColor = user.Role switch
                    {
                        "Admin"    => "bg-danger",
                        "Customer" => "bg-primary",
                        _          => "bg-secondary"
                    };
                    <tr class="@(!user.IsActive ? "table-light" : "")">
                        <td>
                            <p class="fw-semibold mb-0">@user.FullName</p>
                            <small class="text-muted">@user.Email</small>
                        </td>
                        <td><span class="badge @badgeColor">@user.Role</span></td>
                        <td class="text-center">
                            @if (user.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td>
                            <form asp-area="Admin" asp-controller="UserManagement"
                                  asp-action="AssignRole" method="post"
                                  class="d-flex gap-2 align-items-center">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="userId" value="@user.Id" />
                                <select name="role" class="form-select form-select-sm" style="width:auto">
                                    @foreach (var role in allRoles)
                                    {
                                        <option value="@role" selected="@(role == user.Role)">@role</option>
                                    }
                                </select>
                                <button type="submit" class="btn btn-sm btn-outline-primary">Save</button>
                            </form>
                        </td>
                        <td class="text-center text-nowrap">
                            <a asp-area="Admin" asp-controller="UserManagement"
                               asp-action="Details" asp-route-id="@user.Id"
                               class="btn btn-sm btn-outline-secondary me-1">Details</a>
                            @if (user.IsActive)
                            {
                                <form asp-area="Admin" asp-controller="UserManagement"
                                      asp-action="Deactivate" asp-route-id="@user.Id"
                                      method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-warning me-1"
                                            onclick="return confirm('Deactivate this user?')">Deactivate</button>
                                </form>
                            }
                            else
                            {
                                <form asp-area="Admin" asp-controller="UserManagement"
                                      asp-action="Activate" asp-route-id="@user.Id"
                                      method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-success me-1">Activate</button>
                                </form>
                            }
                            @if (!user.HasRelatedData)
                            {
                                <form asp-area="Admin" asp-controller="UserManagement"
                                      asp-action="Delete" asp-route-id="@user.Id"
                                      method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Permanently delete this user? This cannot be undone.')">Delete</button>
                                </form>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-danger" disabled
                                        title="Cannot delete - user has related orders or products">Delete</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="text-center py-5">
        <h4 class="text-muted">No users found</h4>
    </div>
}
