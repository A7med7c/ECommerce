@model UpdateCategoryVM

@{
    ViewData["Title"] = "Admin – Edit Category";
}

<div class="row justify-content-center mt-4">
    <div class="col-6">

        <h2 class="mb-4">
            <i class="fa-solid fa-pen-to-square me-2 text-warning"></i>Edit Category
        </h2>

        <form asp-area="Admin" asp-action="Edit" asp-route-id="@Model.CategoryId" method="post">

            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

            <input type="hidden" asp-for="CategoryId" />

            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ParentCategoryId" class="form-label">Parent Category</label>
                <select asp-for="ParentCategoryId"
                        asp-items="@(new SelectList(Model.ParentCategories, nameof(CategoriesVM.Id), nameof(CategoriesVM.Name)))"
                        class="form-select">
                    <option value="">-- Main Category --</option>
                </select>
            </div>

            <button type="submit" class="btn btn-warning">
                <i class="fa-solid fa-pen-to-square me-1"></i>Update
            </button>
            <a asp-area="Admin" asp-action="Index" class="btn btn-outline-secondary">
                <i class="fa-solid fa-arrow-left me-1"></i>Back
            </a>

        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}